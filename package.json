{
  "name": "proofboard",
  "private": true,
  "version": "0.1.0",
  "description": "Protocol assurance workspace for smart contracts.",
  "workspaces": [
    "apps/web",
    "packages/shared-types",
    "packages/analyzer",
    "packages/property-engine",
    "packages/harness-generator",
    "packages/result-parser",
    "evals"
  ],
  "scripts": {
    "dev": "npm --workspace @proofboard/web run dev",
    "build": "npm --workspace @proofboard/web run build",
    "lint": "npm --workspace @proofboard/web run lint",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "test": "npm --workspaces --if-present run test",
    "test:e2e": "npm --workspace @proofboard/web run test:e2e",
    "eval": "npm --workspace @proofboard/evals run eval"
  },
  "engines": {
    "node": ">=22"
  }
}
